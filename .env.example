# 서버 포트 (기본값: 5000)
PORT=5000

# PostgreSQL 데이터베이스 연결 URL (필수)
# 로컬 PostgreSQL 예시:
DATABASE_URL=postgresql://postgres:password@localhost:5432/pet_groomer

# 세션 시크릿 (프로덕션에서는 반드시 변경)
SESSION_SECRET=your-secret-key-here

# 환경 설정 (development 또는 production)
NODE_ENV=development

# 앱 배포 도메인 (재방문 알림 예약링크 생성에 사용)
# 예: https://jeongrihagae.com
APP_URL=https://your-domain.com

# 솔라피 카카오 알림톡 (https://solapi.com)
# 솔라피 콘솔 > 개발 > API Key 에서 확인
SOLAPI_API_KEY=your-solapi-api-key
SOLAPI_API_SECRET=your-solapi-api-secret
# 솔라피에 등록된 발신번호 (숫자만, 예: 01012345678)
SOLAPI_SENDER_PHONE=01012345678
# 카카오 비즈니스 채널 ID (솔라피 콘솔 > 카카오 채널에서 확인)
KAKAO_PFID=your-kakao-pfid

# 카카오 알림톡 템플릿 코드 (심사 통과 후 솔라피에서 발급)
KAKAO_TEMPLATE_CODE_BOOKING_CONFIRMED=
KAKAO_TEMPLATE_CODE_DEPOSIT_GUIDE=
KAKAO_TEMPLATE_CODE_REMINDER_BEFORE=
KAKAO_TEMPLATE_CODE_BOOKING_CANCELLED=
KAKAO_TEMPLATE_CODE_RETURN_VISIT=

# 포트원 결제 (https://portone.io)
# 포트원 콘솔 > 결제 연동 > 연동 정보에서 확인
VITE_PORTONE_STORE_ID=store-xxxx
VITE_PORTONE_CHANNEL_KEY=channel-key-xxxx
PORTONE_API_SECRET=your-portone-api-secret
